# Copy this file to `.github/FUNDING.yml` and replace the placeholders
# before publishing the repository.
#
# Supported examples:
# github: your-github-handle
# ko_fi: your-kofi-handle
# buy_me_a_coffee: your-buymeacoffee-handle
# custom:
#   - https://yourdomain.com/sponsor

github: your-github-handle
ko_fi: your-kofi-handle
buy_me_a_coffee: your-buymeacoffee-handle
custom:
  - https://yourdomain.com/sponsor
